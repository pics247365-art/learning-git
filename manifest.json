{
  "manifest_version": 3,
  "name": "RTL Adaptive",
  "version": "1.0.0",
  "description": "Pick any element on any website and apply adaptive RTL/LTR direction to it.",
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
